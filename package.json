{
  "name": "obsidian-mdbase",
  "version": "0.2.0",
  "description": "Typed markdown collections via the mdbase spec",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "svelte-check",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,json,css,md,yaml,yml}": "prettier --write"
  },
  "keywords": [],
  "author": "alexlafroscia",
  "license": "MIT",
  "dependencies": {
    "js-yaml": "^4.1.0",
    "micromatch": "^4.0.7"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/micromatch": "^4.0.9",
    "@types/node": "^22.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.21.5",
    "esbuild-svelte": "^0.9.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "obsidian": "^1.4.11",
    "obsidian-typings": "^5.20.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "svelte-preprocess": "^6.0.3",
    "tslib": "^2.6.3",
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@10.33.0",
  "volta": {
    "node": "25.9.0"
  }
}
